+.inventoryModal {
+  color: var(--dp-popup-text, var(--dp-panel-text));
+}
+
+.inventoryPanel {
+  display: grid;
+  gap: 18px;
+}
+
+.inventoryHeader {
+  display: grid;
+  gap: 8px;
+  padding-right: 38px;
+}
+
+.inventoryEyebrow,
+.inventoryItemType,
+.inventoryItemMeta {
+  margin: 0;
+  color: var(--dp-cyber-cyan, #4deaff);
+  font-size: 0.76rem;
+  font-weight: 900;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.inventoryHeader h2 {
+  margin: 0;
+  color: var(--dp-title-gold, var(--dp-brand-yellow));
+  font-size: clamp(1.7rem, 4vw, 2.45rem);
+  line-height: 1;
+  -webkit-text-stroke: 0;
+  text-shadow: none;
+}
+
+.inventoryIntro {
+  max-width: 46rem;
+  margin: 0;
+  color: var(--dp-white-92, rgba(255, 255, 255, 0.92));
+  font-weight: 700;
+  line-height: 1.45;
+}
+
+.inventoryGrid {
+  display: grid;
+  gap: 12px;
+  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
+}
+
+.inventoryItemCard,
+.inventoryEmpty {
+  position: relative;
+  overflow: hidden;
+  border: 2px solid var(--dp-cyber-cyan, #4deaff);
+  border-radius: 16px;
+  background:
+    radial-gradient(
+      circle at 100% 0%,
+      rgba(255, 217, 77, 0.16),
+      transparent 34%
+    ),
+    rgba(3, 12, 28, 0.66);
+  box-shadow:
+    inset 0 0 0 1px rgba(199, 125, 255, 0.32),
+    0 0 18px rgba(77, 234, 255, 0.12);
+}
+
+.inventoryItemCard {
+  display: grid;
+  gap: 10px;
+  min-height: 144px;
+  padding: 14px;
+}
+
+.inventoryItemCardHeader {
+  display: flex;
+  align-items: flex-start;
+  justify-content: space-between;
+  gap: 12px;
+}
+
+.inventoryItemCard h3 {
+  margin: 4px 0 0;
+  color: var(--dp-title-gold, var(--dp-brand-yellow));
+  font-size: 1.04rem;
+  line-height: 1.15;
+  -webkit-text-stroke: 0;
+  text-shadow: none;
+}
+
+.inventoryItemQty {
+  flex: 0 0 auto;
+  min-width: 44px;
+  border: 1px solid var(--dp-border-gold, rgba(255, 217, 77, 0.78));
+  border-radius: 999px;
+  padding: 5px 9px;
+  background: rgba(255, 217, 77, 0.12);
+  color: var(--dp-title-gold, var(--dp-brand-yellow));
+  font-weight: 950;
+  text-align: center;
+}
+
+.inventoryItemDescription,
+.inventoryEmpty p {
+  margin: 0;
+  color: var(--dp-white-92, rgba(255, 255, 255, 0.92));
+  font-weight: 700;
+  line-height: 1.4;
+}
+
+.inventoryItemMeta {
+  align-self: end;
+  color: var(--dp-panel-muted, #a8c8df);
+  letter-spacing: 0.08em;
+}
+
+.inventoryEmpty {
+  display: grid;
+  gap: 8px;
+  padding: 22px;
+  text-align: center;
+}
+
+.inventoryEmptyTitle {
+  color: var(--dp-title-gold, var(--dp-brand-yellow)) !important;
+  font-size: 1.2rem;
+  font-weight: 950;
+}
+
+@media (max-width: 640px) {
+  .inventoryGrid {
+    grid-template-columns: 1fr;
+  }
+
+  .inventoryItemCardHeader {
+    align-items: stretch;
+    flex-direction: column;
+  }
+
+  .inventoryItemQty {
+    width: fit-content;
+  }
+}
