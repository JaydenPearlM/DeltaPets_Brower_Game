+function getPetLabel(pet: PetRecord | null) {
+  return pet?.nickname?.trim() || pet?.name?.trim() || "Your Delta";
+}
+
+function hasNickname(pet: PetRecord | null) {
+  return Boolean(pet?.nickname?.trim());
+}
