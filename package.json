{
  "name": "deltapets",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "frontend/*",
    "backend/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,web \"pnpm --dir backend/server dev\" \"pnpm --dir frontend/web exec vite --host 0.0.0.0\"",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "supabase": "^2.98.2",
    "wait-on": "^8.0.1"
  }
}
